# =============================================================================
# Environment Configuration - Summit Commercial Construction Website
# =============================================================================

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
NODE_ENV=production
SITE_URL=https://summitcommercial-il.com

# ---------------------------------------------------------------------------
# Contact Form Settings (Future API Implementation)
# ---------------------------------------------------------------------------
# SMTP Configuration for contact form emails
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@summitcommercial-il.com
SMTP_TO=info@summitcommercial-il.com

# reCAPTCHA Configuration (v2 or v3)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ---------------------------------------------------------------------------
# Analytics & Tracking (Optional)
# ---------------------------------------------------------------------------
# Google Analytics 4
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
GTM_CONTAINER_ID=GTM-XXXXXXX

# ---------------------------------------------------------------------------
# Monitoring & Logging (Optional)
# ---------------------------------------------------------------------------
# Sentry for error tracking
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Database (Future API Implementation)
# ---------------------------------------------------------------------------
# PostgreSQL or MySQL for contact form storage
DB_HOST=localhost
DB_PORT=5432
DB_NAME=summit_website
DB_USER=db_user
DB_PASS=secure_password

# ---------------------------------------------------------------------------
# Redis (Optional - for rate limiting & caching)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ---------------------------------------------------------------------------
# Security Settings
# ---------------------------------------------------------------------------
# JWT Secret for API authentication (if implementing backend)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------------------------
# Docker Settings
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=summit-website
DOCKER_DEFAULT_PLATFORM=linux/amd64

# ---------------------------------------------------------------------------
# Nginx Settings
# ---------------------------------------------------------------------------
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# ---------------------------------------------------------------------------
# SSL/TLS Certificate Paths (for manual SSL configuration)
# ---------------------------------------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/summitcommercial-il.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/summitcommercial-il.com/privkey.pem
